{
  "manifest_version": 3,
  "name": "Interview AI - Meeting Copilot",
  "version": "1.0.2",
  "description": "AI meeting assistant for Google Meet and Teams. Private transcription, question detection, and AI answers.",
  "permissions": ["storage", "scripting", "activeTab", "tabs", "tabCapture", "offscreen", "identity"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Meeting Copilot",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["content/platform.js", "content/overlay.js", "content/content.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
